<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>지역 보건소 실시간 혼잡도 안내</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Malgun Gothic', sans-serif;
        }

        body {
            background-color: #f5f7fa;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            background-color: #ffffff;
            width: 100%;
            max-width: 480px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
            padding: 30px;
            text-align: center;
        }

        h1 {
            font-size: 1.6rem;
            color: #2c3e50;
            margin-bottom: 10px;
        }

        .time-info {
            font-size: 1.05rem;
            color: #7f8c8d;
            margin-bottom: 20px;
            padding: 8px 12px;
            background-color: #edf2f7;
            border-radius: 8px;
            display: inline-block;
        }

        /* 메인 유의사항 알림 */
        .notice-box {
            background-color: #fff5f5;
            border: 1px solid #feb2b2;
            padding: 10px 14px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: left;
        }

        .notice-red {
            color: #e53e3e;
            font-size: 0.85rem;
            font-weight: bold;
            margin-bottom: 4px;
        }

        .notice-gray {
            color: #718096;
            font-size: 0.8rem;
        }

        /* 혼잡도 카드 스타일 */
        .status-card {
            padding: 25px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        /* 5단계 혼잡도 색상 스타일 */
        .status-crowded { /* 혼잡: 빨강 */
            background-color: #ffebee;
            color: #c62828;
            border: 2px solid #ffcdd2;
        }
        .status-slightly-crowded { /* 조금 혼잡: 주황 */
            background-color: #fff3e0;
            color: #e65100;
            border: 2px solid #ffe0b2;
        }
        .status-normal { /* 보통: 노랑 */
            background-color: #fffde7;
            color: #f57f17;
            border: 2px solid #fff59d;
        }
        .status-slightly-smooth { /* 조금 여유: 초록 */
            background-color: #e8f5e9;
            color: #2e7d32;
            border: 2px solid #a5d6a7;
        }
        .status-smooth { /* 여유: 파랑 */
            background-color: #e3f2fd;
            color: #1565c0;
            border: 2px solid #bbdefb;
        }
        .status-closed { /* 운영 외/휴무: 회색 */
            background-color: #f5f5f5;
            color: #616161;
            border: 2px solid #e0e0e0;
        }

        .status-title {
            font-size: 2.3rem;
            margin-bottom: 8px;
            letter-spacing: 2px;
        }

        .status-desc {
            font-size: 1rem;
        }

        /* 상세 정보 표시 영역 */
        .data-details {
            text-align: left;
            background-color: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            font-size: 0.95rem;
            border-left: 4px solid #3498db;
            margin-bottom: 25px;
        }

        .data-details p {
            margin-bottom: 6px;
        }
        .data-details p:last-child {
            margin-bottom: 0;
        }

        .highlight {
            font-weight: bold;
            color: #2980b9;
        }

        /* 수동 선택 영역 */
        .search-section {
            border-top: 1px dashed #bdc3c7;
            padding-top: 25px;
            text-align: left;
        }

        .search-section h3 {
            font-size: 1.1rem;
            color: #34495e;
            margin-bottom: 12px;
            text-align: center;
        }

        .select-box {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        select {
            flex: 1;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 0.9rem;
            background-color: #fff;
            cursor: pointer;
        }

        .btn-search {
            width: 100%;
            background-color: #3498db;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-search:hover {
            background-color: #2980b9;
        }

        footer {
            margin-top: 25px;
            font-size: 0.8rem;
            color: #bdc3c7;
        }
    </style>
</head>
